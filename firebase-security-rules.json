{
  "rules": {
    "peserta": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$pesertaId": {
        ".validate": "auth != null"
      }
    },
    "program": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$programId": {
        ".validate": "auth != null"
      }
    },
    "kontrak": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$kontrakId": {
        ".validate": "auth != null"
      }
    },
    "krs": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$krsId": {
        ".validate": "auth != null"
      }
    },
    "pendaftar": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$pendaftarId": {
        ".validate": "auth != null"
      }
    },
    "paket": {
      ".read": "true",
      ".write": "auth != null",
      "$paketId": {
        ".validate": "auth != null"
      }
    },
    "admin": {
      ".read": "auth != null && auth.uid === 'YOUR_ADMIN_UID'",
      ".write": "auth != null && auth.uid === 'YOUR_ADMIN_UID'"
    }
  }
}
